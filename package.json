    "mongoose": "^8.19.2",
    "octokit": "^5.0.4",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
